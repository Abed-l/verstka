        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(95deg, #9B4DFF, #6C1BB5);
            border: none;
            border-radius: 40px;
            color: white;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            margin-top: 12px;
        }

        .register-link {
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: #B9B3D4;
        }

        .register-link a {
            color: #C27EFF;
            text-decoration: none;
        }

        .calendar-section {
            background: #1D1A26;
            border-radius: 32px;
            padding: 28px;
            margin: 40px 0;
            border: 1px solid #363141;
        }

        .month-title {
            font-size: 28px;
            font-weight: 800;
            color: #C682FF;
        }

        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            cursor: pointer;
            border-radius: 60px;
            transition: 0.2s;
        }

        .calendar-day.selected {
            background: #9B4DFF;
            color: white;
        }

        .time-slot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #26222F;
            padding: 12px 24px;
            border-radius: 60px;
            margin-bottom: 12px;
        }

        .book-btn {
            background: linear-gradient(95deg, #9B4DFF, #6C1BB5);
            border: none;
            border-radius: 60px;
            padding: 8px 24px;
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        .book-btn.disabled {
            background: #3C3548;
            color: #FF8A8A;
            cursor: not-allowed;
        }

        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #1E1B28;
            backdrop-filter: blur(12px);
            border: 1px solid #9B4DFF;
            border-radius: 60px;
            padding: 12px 28px;
            color: white;
            font-weight: 500;
            z-index: 200;
            box-shadow: 0 6px 18px rgba(0,0,0,0.4);
            transition: opacity 0.2s;
            pointer-events: none;
        }

        button, .like-btn {
            transition: 0.2s;
        }

        @media (max-width: 720px) {
            .container {
                padding: 0 16px;
            }
            .time-slot {
                flex-direction: column;
                text-align: center;
                gap: 10px;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="container">
        <div class="header-content">
            <div class="logo">✨ BRONI.COM</div>
            <div class="url-bar">
                <div class="url-icon"></div>
                <span class="url-text">https://broni.com</span>
            </div>
            <div class="status-icons">
                <span>📶 5G</span>
                <span>🔋 87%</span>
                <span>🕒 21:45</span>
            </div>
        </div>
    </div>
</div>

<main>
    <div class="container">
        <div style="display: flex; gap: 16px; justify-content: center; margin: 20px 0; flex-wrap: wrap;">
            <button onclick="showPage('main')" class="nav-btn" style="background:#9B4DFF; border:none; padding:10px 24px; border-radius:40px; color:white; cursor:pointer;">Главная</button>
            <button onclick="showPage('auth')" class="nav-btn" style="background:#2C263B; border:none; padding:10px 24px; border-radius:40px; color:white; cursor:pointer;">Авторизация</button>
            <button onclick="showPage('booking')" class="nav-btn" style="background:#2C263B; border:none; padding:10px 24px; border-radius:40px; color:white; cursor:pointer;">Бронирование</button>
            <button onclick="showPage('profile')" class="nav-btn" style="background:#2C263B; border:none; padding:10px 24px; border-radius:40px; color:white; cursor:pointer;">Профиль</button>
        </div>

        <div id="page-main" class="page">
            <div class="hero">
                <h1>Бронирование</h1>
                <p>общих ресурсов</p>
            </div>
            <div style="margin-top: 10px;">
                <h2 style="font-size: 26px;">Рекомендации</h2>
                <div class="services-grid" id="servicesGrid"></div>
            </div>
        </div>

        <div id="page-auth" class="page" style="display: none;">
            <div class="auth-form">
                <h2>Вход</h2>
                <div class="input-group">
                    <input type="email" id="loginEmail" placeholder="Email">
                </div>
                <div class="input-group">
                    <input type="password" id="loginPassword" placeholder="Пароль">
                </div>
                <button class="login-btn" id="doLoginBtn">Войти</button>
                <div class="register-link">Нет аккаунта? <a href="#">Зарегистрироваться</a></div>
            </div>
        </div>

        <div id="page-booking" class="page" style="display: none;">
            <div class="calendar-section">
                <div class="month-title">МАЙ 2025</div>
                <div class="service-name" style="margin: 8px 0 16px; color:#C27EFF;">МАНИКЮР “BeMy”</div>
                <div class="weekdays" style="display:grid; grid-template-columns:repeat(7,1fr); text-align:center; gap:6px; font-weight:600;">ПН ВТ СР ЧТ ПТ СБ ВС</div>
                <div class="calendar-days" id="calendar-days"></div>
            </div>
            <div class="time-slots">
                <h3>Время на выбранную дату</h3>
                <div id="time-slots-container"></div>
            </div>
        </div>

        <div id="page-profile" class="page" style="display: none;">
            <div style="display: flex; flex-direction: column; align-items: center; padding: 40px 0;">
                <div style="width: 110px; height: 110px; background: #2A2537; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 52px; margin-bottom: 20px;">👤</div>
                <h2>Иван Иванович</h2>
                <p style="color:#ACA9C9;">ivan@broni.com</p>
                <div style="width: 100%; max-width: 440px; margin-top: 30px;">
                    <div class="time-slot" style="justify-content: flex-start; gap: 18px;"><span>⭐</span> Избранное</div>
                    <div class="time-slot" style="justify-content: flex-start; gap: 18px;"><span>📅</span> Мой календарь</div>
                    <div class="time-slot" style="justify-content: flex-start; gap: 18px;"><span>⚙️</span> Настройки</div>
                    <div class="time-slot" style="justify-content: flex-start; gap: 18px; color:#FF8989;"><span>🚪</span> Выйти</div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    function showToast(message) {
        let oldToast = document.querySelector('.toast');
        if(oldToast) oldToast.remove();
        let toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerText = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }

    function attachLikeEvents() {
        document.querySelectorAll('.like-btn').forEach(btn => {
            btn.removeEventListener('click', handleLike);
            btn.addEventListener('click', handleLike);
        });
    }

    function handleLike(e) {
        e.stopPropagation();
        showToast('❤️ Добавлено в избранное');
    }

    const services = [
        { title: "Фотограф на мероприятие", loc: "г. Иркутск", price: "от 5000 ₽", emoji: "📸" },
        { title: "Конференц-зал 'Европа'", loc: "ул. Байкальская, 69", price: "от 2000 ₽/час", emoji: "🏢" },
        { title: "Маникюр в студии 'BeMy'", loc: "ул. Дзержинского, 1", price: "от 1500 ₽", emoji: "💅" },
        { title: "Автомобиль 'Ford Mustang'", loc: "г. Иркутск", price: "от 3000 ₽/день", emoji: "🚗" }
    ];

    function renderServices() {
        const grid = document.getElementById('servicesGrid');
        if(!grid) return;
        grid.innerHTML = services.map(s => `
            <div class="service-card">
                <div class="card-image">${s.emoji}</div>
                <div class="card-content">
                    <div class="card-title">${s.title}</div>
                    <div class="card-location">📍 ${s.loc}</div>
                    <div class="card-footer">
                        <span class="price">${s.price}</span>
                        <div class="like-btn">❤️ В избранное</div>
                    </div>
                </div>
            </div>
        `).join('');
        attachLikeEvents();
    }

    let selectedDateNum = 21;

    function renderCalendar() {
        const year = 2025, month = 4;
        const firstDay = new Date(year, month, 1);
        let startOffset = (firstDay.getDay() === 0 ? 6 : firstDay.getDay() - 1);
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const container = document.getElementById('calendar-days');
        if(!container) return;
        container.innerHTML = '';
        for(let i=0; i<startOffset; i++) {
            let empty = document.createElement('div');
            empty.className = 'calendar-day';
            empty.style.opacity = '0.3';
            container.appendChild(empty);
        }
        for(let d=1; d<=daysInMonth; d++) {
            let dayDiv = document.createElement('div');
            dayDiv.innerText = d;
            dayDiv.className = 'calendar-day';
            if(d === selectedDateNum) dayDiv.classList.add('selected');
            dayDiv.onclick = (function(day) {
                return function() {
                    document.querySelectorAll('#calendar-days .calendar-day').forEach(el => el.classList.remove('selected'));
                    dayDiv.classList.add('selected');
                    selectedDateNum = day;
                    renderTimeSlots();
                };
            })(d);
            container.appendChild(dayDiv);
        }
        renderTimeSlots();
    }

    function renderTimeSlots() {
        const slots = [
            { time: '12:00', available: true },
            { time: '14:00', available: false },
            { time: '16:00', available: true },
            { time: '18:00', available: true },
            { time: '20:00', available: true }
        ];
        const container = document.getElementById('time-slots-container');
        if(!container) return;
        container.innerHTML = slots.map(slot => `
            <div class="time-slot">
                <div style="font-weight:600;">${slot.time}</div>
                <button class="book-btn ${!slot.available ? 'disabled' : ''}" ${!slot.available ? 'disabled' : ''} data-time="${slot.time}">
                    ${slot.available ? 'Забронировать' : 'Занято'}
                </button>
            </div>
        `).join('');
        document.querySelectorAll('.book-btn:not(.disabled)').forEach(btn => {
            btn.removeEventListener('click', bookingHandler);
            btn.addEventListener('click', bookingHandler);
        });
    }

    function bookingHandler(e) {
        e.stopPropagation();
        showToast('✅ Успешно забронировано! Время подтверждено');
    }

    function initAuth() {
        const btn = document.getElementById('doLoginBtn');
        if(btn) {
            btn.removeEventListener('click', authHandler);
            btn.addEventListener('click', authHandler);
        }
    }

    function authHandler() {
        let email = document.getElementById('loginEmail')?.value.trim();
        if(!email) email = "demo@broni.com";
        showToast(`🔐 Добро пожаловать, ${email.split('@')[0]}!`);
    }

    function showPage(pageId) {
        document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
        document.getElementById(`page-${pageId}`).style.display = 'block';
        document.querySelectorAll('.nav-btn').forEach(btn => btn.style.background = '#2C263B');
        if(event?.target) event.target.style.background = '#9B4DFF';
        if(pageId === 'booking') renderCalendar();
        if(pageId === 'main') renderServices();
        if(pageId === 'auth') initAuth();
    }

    renderServices();
    renderCalendar();
    initAuth();
</script>
</body>
</html>
